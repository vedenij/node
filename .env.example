# === Set these in Vast.ai template environment variables ===

# Security - REQUIRED
API_KEY=your_api_key_here

# Node worker port (exposed to orchestrator)
PORT=9000

# vLLM (co-located, started by startup.sh)
VLLM_HOST=127.0.0.1
VLLM_PORT=8000

# Model (downloaded from HuggingFace on first run)
MODEL_NAME=Qwen/Qwen3-235B-A22B-Instruct-2507-FP8
SEQ_LEN=1024
K_DIM=12

# HuggingFace cache (mount a volume here to persist model between restarts)
# HF_HOME=/root/.cache/huggingface

LOG_LEVEL=INFO
